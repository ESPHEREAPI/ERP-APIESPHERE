app.jwt.secret=${JWT_SECRET}
#app.jwt.secret=8f3d9a2c1b7e4f6a9c2d5e8f1a3b6c9d7e2f4a6b8c1d3e5f7a9c2b4d6e8f1a3
app.jwt.expiration-ms=86400000

