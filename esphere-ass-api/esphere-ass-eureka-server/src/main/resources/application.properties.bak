# ========================================
# ESPHERE-ASS EUREKA SERVER
# Registre de services Spring Cloud Netflix
# ========================================

spring.application.name=esphere-ass-eureka-server
server.port=8762

# ========================================
# Config Server (dev local)
# Le bootstrap.yml prend le relais au démarrage
# ========================================
spring.cloud.config.uri=http://localhost:8888
spring.cloud.config.enabled=false
spring.cloud.compatibility-verifier.enabled=false

# ========================================
# Mode standalone — le serveur Eureka
# ne s'enregistre pas chez lui-même
# ========================================
eureka.client.register-with-eureka=false
eureka.client.fetch-registry=false

# Dev local
eureka.instance.hostname=localhost
eureka.instance.ip-address=127.0.0.1
eureka.instance.prefer-ip-address=true
eureka.instance.non-secure-port=${server.port}
eureka.client.service-url.defaultZone=http://localhost:${server.port}/eureka/

# ========================================
# Optimisations serveur
# ========================================
eureka.server.wait-time-in-ms-when-sync-empty=0
eureka.server.enable-self-preservation=false
eureka.server.eviction-interval-timer-in-ms=5000
eureka.server.renewal-percent-threshold=0.49

# ========================================
# Actuator
# ========================================
management.endpoints.web.exposure.include=health,info
management.endpoint.health.show-details=always

# ========================================
# Logging
# ========================================
logging.level.root=INFO
logging.level.com.netflix.eureka=INFO
logging.level.com.netflix.discovery=INFO
