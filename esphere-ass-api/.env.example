# ==============================================================================
# ESPHERE-ASS — Variables d'environnement Production
#
# 1. Copier ce fichier : cp .env.example .env
# 2. Remplir TOUTES les valeurs obligatoires (marquées [OBLIGATOIRE])
# 3. Ne jamais commiter le fichier .env dans Git
# ==============================================================================

# ── Serveur ────────────────────────────────────────────────────────────────────
# IP publique du serveur VPS
SERVER_IP=77.68.94.193

# ── Oracle Database  [OBLIGATOIRE] ─────────────────────────────────────────────
# Format thin : jdbc:oracle:thin:@//HOST:PORT/SERVICE_NAME
ORACLE_URL=jdbc:oracle:thin:@//77.68.94.193:1521/ORCL
ORACLE_USER=esphere_user
ORACLE_PASSWORD=change_me_strong_password

# ── Sécurité JWT  [OBLIGATOIRE] ────────────────────────────────────────────────
# Clé secrète HS256 — minimum 256 bits (64 caractères hex)
# Générer : openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64

# ── SSL / Keystore PKCS12  [OBLIGATOIRE] ───────────────────────────────────────
# Placer le fichier keystore.p12 dans le dossier ./certs/
# Générer un certificat auto-signé : bash generate-ssl-cert.sh
# En production réelle : utiliser un certificat Let's Encrypt ou CA officielle
KEYSTORE_PASSWORD=change_me_keystore_password
KEY_ALIAS=gateway

# ── Config Server — Dépôt Git  [OBLIGATOIRE] ───────────────────────────────────
# Dépôt Git contenant les configurations centralisées des microservices
GIT_CONFIG_URI=https://github.com/ESPHEREAPI/esphere-ass-erp.git
GIT_CONFIG_BRANCH=main
# Laisser vide si le dépôt est public
GIT_USERNAME=
GIT_PASSWORD=

# ── Services externes (optionnel) ──────────────────────────────────────────────
SERVICE_BIOMETRIE_URL=http://77.68.94.193:8081
SERVICE_BIOMETRIE_PART_URL=http://77.68.94.193:8082
