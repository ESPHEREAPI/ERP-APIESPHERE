# ═══════════════════════════════════════════════════════════════
# ESPHERE BIOMETRY — Variables d'environnement
# Copier ce fichier en .env.prod et renseigner les vraies valeurs
# NE JAMAIS commiter .env.prod dans git
# ═══════════════════════════════════════════════════════════════

# ── Profil Spring (dev | prod) ─────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Infrastructure ─────────────────────────────────────────────
ESPHERE_HOST=109.228.49.89
EUREKA_HOSTNAME=109.228.49.89
CONFIG_HOST=109.228.49.89
LOG_PATH=C:/esphere/logs

# ── Base de données MySQL ──────────────────────────────────────
DB_HOST=109.228.49.89
DB_PORT=3306
DB_NAME=biometry
DB_USERNAME=esphere_user
DB_PASSWORD=CHANGEZ_MOI

# ── Sécurité JWT ───────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
JWT_SECRET=CHANGEZ_MOI_MINIMUM_64_CARACTERES_HEX
JWT_EXPIRATION=86400000

# ── OTP ────────────────────────────────────────────────────────
OTP_SECRET=CHANGEZ_MOI

# ── Eureka Server ──────────────────────────────────────────────
EUREKA_ADMIN_USER=admin
EUREKA_ADMIN_PASSWORD=CHANGEZ_MOI

# ── Config Server ──────────────────────────────────────────────
CONFIG_GIT_URI=https://github.com/ESPHEREAPI/ERP-APIESPHERE.git

# ── Gateway SSL ────────────────────────────────────────────────
SSL_KEYSTORE_PATH=C:/esphere/certs/keystore.p12
SSL_KEYSTORE_PASSWORD=CHANGEZ_MOI

# ── Email (Notification Service) ───────────────────────────────
MAIL_HOST=secure.emailsrvr.com
MAIL_PORT=587
MAIL_USERNAME=info@zenitheinsurance.com
MAIL_PASSWORD=CHANGEZ_MOI
MAIL_FROM=info@zenitheinsurance.com

# ── SMS (Notification Service) ─────────────────────────────────
SMS_API_URL=https://smsvas.com/bulk/public/index.php/api/v1/sendsms
SMS_API_USER=info@zenitheinsurance.com
SMS_API_PASSWORD=CHANGEZ_MOI
SMS_SENDER_ID=ZENITHE

# ── Média ──────────────────────────────────────────────────────
MEDIA_STORAGE_PATH=C:/biometry-media
UPLOAD_MAX_FILE_SIZE=100MB
UPLOAD_MAX_REQUEST_SIZE=105MB
MEDIA_CAPTURE_EXPIRY_HOURS=24

# ── CORS Gateway ───────────────────────────────────────────────
# (configuré directement dans application-prod.yml)
